# Crypto Trading Bot Configuration
# Copy this to .env and fill in your values

# Environment Settings
ENVIRONMENT=development
DEBUG=true
PAPER_TRADING=true

# Database Configuration
DATABASE_URL=sqlite:///trading_db_test.db
REDIS_URL=redis://localhost:6379

# API Keys (Optional for development with paper trading)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true

# OpenAI Configuration (Optional - for AI features)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.1

# News API Keys (Optional)
NEWSAPI_KEY=
CRYPTOPANIC_API_KEY=
COINMARKETCAP_API_KEY=

# Trading Configuration
MAX_POSITION_SIZE=0.1
RISK_PER_TRADE=0.02
MIN_CONFIDENCE_SCORE=0.7
MAX_POSITIONS=5

# Security
JWT_SECRET_KEY=your-secret-key-change-in-production

# Monitoring
LOG_LEVEL=INFO
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=crypto-trading-bot
LANGSMITH_TRACING=false

# Performance
CACHE_TTL_MARKET_DATA=30
BATCH_SIZE_ORDERS=50
