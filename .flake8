[flake8]
max-line-length = 100
max-complexity = 10
exclude =
    .git,
    __pycache__,
    docs/,
    venv/,
    .venv/,
    .eggs/,
    *.egg,
    build/,
    dist/,
    migrations/,
    .tox,
    .hypothesis
ignore = E203, E266, W503, E501, F401
per-file-ignores =
    __init__.py:F401
    tests/*:F401,F811
    src/ui/streamlit_app.py:E501
